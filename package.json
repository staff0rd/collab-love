{
  "name": "collab-love",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build --logLevel error",
    "preview": "vite preview",
    "ios:sync": "npm run build && cap sync ios",
    "ios:run": "npm run build && cap run ios --target FADDB257-6AC2-43BF-A04E-F269F3343A68",
    "ios:open": "cap open ios",
    "assets:generate": "capacitor-assets generate --ios"
  },
  "dependencies": {
    "@capacitor/cli": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@ionic/react": "^8.8.13",
    "@ionic/react-router": "^8.8.13",
    "ionicons": "^8.0.13",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "^5.3.4",
    "react-router-dom": "^5.3.4"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-router": "^5.1.20",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jscpd": "^5.0.11",
    "knip": "^6.24.0",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "typescript": "~6.0.3",
    "vite": "^8.1.3"
  }
}
